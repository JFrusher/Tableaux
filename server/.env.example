# Tableaux server configuration. Copy to `.env` and fill in.
#
# For LOCAL development with the Supabase CLI, run `npx supabase status -o env`
# and copy the printed API URL + keys into the SUPABASE_* values below.

# Port the API listens on.
PORT=3001
# Origin allowed by CORS (the client URL).
CLIENT_ORIGIN=http://localhost:5173

# Supabase — leave blank to run in legacy single-tenant, NO-AUTH local mode.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Server-only. BYPASSES Row-Level Security. NEVER expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=
