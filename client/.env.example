# Client configuration. Vite only exposes VITE_-prefixed vars to the browser.
#
# Leave the SUPABASE values blank to run in legacy, no-login local mode (the
# client talks to the file-based /api/state). Set them to enable sign-in and the
# multi-tenant /api/plans backend. For local dev use the values from
# `npx supabase status` (API URL + anon key — never the service_role key).

VITE_API_BASE=/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Public origin of the deployed site (no trailing slash), e.g.
# https://tableaux.onrender.com or a custom domain. Baked into the canonical,
# Open Graph and Twitter meta tags at build time. Leave blank for local dev.
VITE_PUBLIC_URL=

# ── Dev-only auth bypass (ignored in production builds) ──────────────────────
# Set to true to auto-skip the login screen on load by signing into a fixed dev
# account (created on first use). A "Skip sign-in (dev)" button is always shown
# in dev regardless. These use the REAL auth + RLS path — they just skip typing.
VITE_DEV_AUTH_BYPASS=false
VITE_DEV_USER_EMAIL=dev@tableaux.local
VITE_DEV_USER_PASSWORD=devpassword123

